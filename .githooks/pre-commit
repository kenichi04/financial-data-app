#!/bin/sh
# Flywayマイグレーションを変更したコミットに、再生成したjOOQ生成物が含まれているかチェックする。
# 有効化（clone後に1回）: git config core.hooksPath .githooks
# 背景: docs/jooq_codegen_improvement.md
#
# 制約: 生成物の「有無」しか見ない簡易チェック。内容の鮮度はCIの再生成一致チェック（Step 3）で担保する。
# データ投入のみ・インデックス追加のみ等、生成物に差分が出ないマイグレーションは --no-verify で通してよい。

staged=$(git diff --cached --name-only)

echo "$staged" | grep -q '^backend/src/main/resources/db/migration/' || exit 0

if echo "$staged" | grep -q '^backend/src/generated/jooq/'; then
    exit 0
fi

cat >&2 <<'MSG'
[pre-commit] Flywayマイグレーションが変更されていますが、jOOQ生成物
(backend/src/generated/jooq/) の更新がコミットに含まれていません。

  対処:
    docker-compose up -d
    cd backend && ./mvnw flyway:migrate && ./mvnw generate-sources -Pjooq-codegen
    git add backend/src/generated/jooq

  生成物に差分が出ない変更（データ投入のみ等）の場合:
    git commit --no-verify

  詳細: docs/jooq_codegen_improvement.md
MSG
exit 1
